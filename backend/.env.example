# Banco de Dados
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=guia_domestico

# Aplicação
APP_ENV=development
APP_DEBUG=True
SECRET_KEY=sua-chave-secreta-desenvolvimento-aqui
PORT=5000

# JWT
JWT_SECRET_KEY=sua-chave-jwt-desenvolvimento-aqui
JWT_EXPIRATION_HOURS=24

# CORS
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# Email (opcional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-app

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
